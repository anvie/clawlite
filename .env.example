# ========================================
# ClawLite Configuration
# ========================================

# Enabled channels (comma-separated: telegram, whatsapp)
ENABLED_CHANNELS=telegram

# ========================================
# LLM Provider
# ========================================

# Provider: ollama or openrouter
LLM_PROVIDER=ollama

# --- Ollama Config (when LLM_PROVIDER=ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- OpenRouter Config (when LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_MODEL=google/gemini-2.5-pro-preview-03-25
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ========================================
# Telegram Channel
# ========================================

# Bot Token from @BotFather
TELEGRAM_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated, empty = allow all)
TELEGRAM_ALLOWED_USERS=

# ========================================
# WhatsApp Channel
# ========================================

# Session directory for WhatsApp authentication
WHATSAPP_SESSION_DIR=/data/whatsapp

# Allowed phone numbers (comma-separated, e.g., 628xxx,628yyy)
# Empty = allow all
WHATSAPP_ALLOWED_USERS=

# ========================================
# General
# ========================================

# Global allowed users (fallback if channel-specific not set)
ALLOWED_USERS=

# Workspace path inside container
WORKSPACE_PATH=/workspace

# Translation (optional)
TRANSLATION_ENABLED=false
TRANSLATION_API=http://localhost:7655
