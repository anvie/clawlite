# ========================================
# ClawLite - Secrets Only
# ========================================
# All other config goes in config.yaml
#
# ENCRYPTION SUPPORT:
# Values can be encrypted using envcrypt CLI:
#   envcrypt init --generate     # First time setup
#   envcrypt encrypt .env -i     # Encrypt in-place
#
# Encrypted values look like:
#   TELEGRAM_TOKEN=encrypted:base64data...
#
# Install envcrypt: cargo install --git https://github.com/aisyahsyihab/envcrypt

# === API Keys ===

# OpenRouter (if using openrouter provider)
OPENROUTER_API_KEY=

# Anthropic (if using anthropic provider)
# Option 1: API Key from console.anthropic.com
ANTHROPIC_API_KEY=
# Option 2: OAuth token from `claude setup-token`
ANTHROPIC_AUTH_TOKEN=

# === Bot Tokens ===

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=

# === Skill Credentials (add as needed) ===
# KRASAN_API_KEY=
# KRASAN_API_SECRET=

# === Encryption Key (for Docker) ===
# If using encrypted .env, set this OR mount ~/.envcrypt.yaml
# ENVCRYPT_KEY=
