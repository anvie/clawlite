#!/bin/bash
# ClawLite - Send message to user via API
# Usage: clawlite-send <user_id> <message>
#
# Examples:
#   clawlite-send tg_123456 "Time to ngaji!"
#   clawlite-send wa_628123 "Reminder: Meeting in 5 min"

set -e

API_PORT="${API_PORT:-8080}"
API_HOST="${API_HOST:-127.0.0.1}"

if [ $# -lt 2 ]; then
    echo "Usage: clawlite-send <user_id> <message>" >&2
    exit 1
fi

USER_ID="$1"
shift
MESSAGE="$*"

# Call API endpoint
RESPONSE=$(curl -s -w "\n%{http_code}" -X POST "http://${API_HOST}:${API_PORT}/api/send" \
    -H "Content-Type: application/json" \
    -d "{\"user\": \"${USER_ID}\", \"message\": \"${MESSAGE}\"}")

# Extract HTTP status code (last line)
HTTP_CODE=$(echo "$RESPONSE" | tail -n1)
BODY=$(echo "$RESPONSE" | sed '$d')

if [ "$HTTP_CODE" = "200" ]; then
    echo "✓ Message sent to $USER_ID"
    exit 0
else
    echo "✗ Failed to send message (HTTP $HTTP_CODE): $BODY" >&2
    exit 1
fi
