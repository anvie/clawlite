#!/bin/bash
# ClawLite - Send message to user
# Usage: clawlite-send <user_id> <message>
#
# Examples:
#   clawlite-send tg_123456 "Time to ngaji!"
#   clawlite-send wa_628123 "Reminder: Meeting in 5 min"

set -e

# Source environment variables (for cron jobs)
ENV_FILE="/app/.env.cron"
if [ -f "$ENV_FILE" ]; then
    set -a
    source "$ENV_FILE"
    set +a
fi

if [ $# -lt 2 ]; then
    echo "Usage: clawlite-send <user_id> <message>" >&2
    exit 1
fi

USER_ID="$1"
shift
MESSAGE="$*"

# Use main entry point with send subcommand
cd /app
exec python -m src.main send --user "$USER_ID" --message "$MESSAGE"
