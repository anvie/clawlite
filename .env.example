# ========================================
# ClawLite - Secrets Only
# ========================================
# All other config goes in config.yaml

# === API Keys ===

# OpenRouter (if using openrouter provider)
OPENROUTER_API_KEY=

# Anthropic (if using anthropic provider)
# Option 1: API Key from console.anthropic.com
ANTHROPIC_API_KEY=
# Option 2: OAuth token from `claude setup-token`
ANTHROPIC_AUTH_TOKEN=

# === Bot Tokens ===

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=

# === Skill Credentials (add as needed) ===
# KRASAN_API_KEY=
# KRASAN_API_SECRET=
